rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Staff are authenticated with non-anonymous providers (e.g. password, google)
    function isStaff() {
      return isAuthenticated() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /restaurants/{restaurantId} {
      // Restaurant info is public (name, logo, etc.)
      allow read: if true;
      // Only staff can update restaurant details
      allow write: if isStaff();

      match /menuItems/{itemId} {
        // Menu is publicly readable (customers browse it)
        allow read: if true;
        // Only staff can add/edit/delete menu items
        allow write: if isStaff();
      }
      
      match /sessions/{sessionId} {
        // Any authenticated user can read sessions (needed for table lookup)
        allow read: if isAuthenticated() || isStaff();
        // Any authenticated user can create a session
        allow create: if isAuthenticated();
        // Update allowed by session owner (adding orders) or staff (closing session)
        allow update: if isAuthenticated() || isStaff();
        // Only staff can delete sessions
        allow delete: if isStaff();
      }

      match /orders/{orderId} {
        // Authenticated users can read orders (needed for session order display)
        allow read: if isAuthenticated() || isStaff();
        // Authenticated users can create orders
        allow create: if isAuthenticated();
        // Only staff can update orders (status changes) or delete
        allow update, delete: if isStaff();
      }
    }
  }
}
